<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fafafa;
            color: #3a3a3a;
        }

        .card {
            width: 100%;
            max-width: 380px;
            padding: 44px 40px;
            margin: 20px;
            background: #fff;
            border-radius: 12px;
            border: 1px solid #eee;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        }

        h2 {
            font-size: 22px;
            font-weight: 500;
            letter-spacing: -0.3px;
            margin-bottom: 4px;
        }

        .subtitle {
            font-size: 13px;
            color: #999;
            font-weight: 300;
            margin-bottom: 36px;
        }

        .input-group {
            margin-bottom: 16px;
        }

        .input-group label {
            display: block;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #aaa;
            margin-bottom: 6px;
        }

        .input-group input {
            width: 100%;
            padding: 11px 0;
            background: transparent;
            border: none;
            border-bottom: 1px solid #ddd;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            color: #3a3a3a;
            outline: none;
            transition: border-color 0.3s;
        }

        .input-group input:focus {
            border-bottom-color: #3a3a3a;
        }

        .input-group input::placeholder {
            color: #ccc;
        }

        .submit-btn {
            width: 100%;
            padding: 12px;
            margin-top: 28px;
            background: #3a3a3a;
            color: #f4f2ee;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            font-family: 'Inter', sans-serif;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: opacity 0.3s;
        }

        .submit-btn:hover {
            opacity: 0.8;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 14px;
            margin: 28px 0;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #ddd;
        }

        .divider span {
            font-size: 11px;
            color: #bbb;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .google-btn {
            width: 100%;
            padding: 11px;
            background: transparent;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            color: #3a3a3a;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: border-color 0.3s;
        }

        .google-btn:hover {
            border-color: #aaa;
        }

        .google-btn img {
            width: 16px;
            height: 16px;
        }

        .login-link {
            text-align: center;
            margin-top: 32px;
            font-size: 13px;
            color: #aaa;
            font-weight: 300;
        }

        .login-link a {
            color: #3a3a3a;
            text-decoration: none;
            font-weight: 500;
        }

        .login-link a:hover {
            text-decoration: underline;
        }

        @media (max-width: 480px) {
            .card {
                padding: 36px 24px;
            }
        }
    </style>
</head>

<body>

    <div class="card">
        <h2>Create Account</h2>
        <p class="subtitle">Enter your details below</p>

        <form action="/check-otp" method="post">
            <div class="input-group">
                <label>Name</label>
                <input type="text" placeholder="Your full name" name="name" required />
            </div>

            <div class="input-group">
                <label>Email</label>
                <input type="email" placeholder="you@example.com" name="email" required />
            </div>

            <div class="input-group">
                <label>Password</label>
                <input type="password" placeholder="••••••••" name="password" required />
            </div>

            <button type="submit" class="submit-btn">Sign Up</button>
        </form>

        <div class="divider"><span>or</span></div>

        <form action="/auth/google" method="get">
            <button type="submit" class="google-btn">
                <img src="/images/google_logo.svg" alt="Google">
                Continue with Google
            </button>
        </form>

        <p class="login-link">Have an account? <a href="/login">Sign in</a></p>
    </div>

</body>

</html>